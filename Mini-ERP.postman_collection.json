      "name": "Auth",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"password\": \"password123\",\n    \"user\": {\n        \"name\": \"Admin User\",\n        \"email\": \"admin@erp.com\",\n        \"role\": \"admin\"\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/users/create-user",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "create-user"
              ]
            }
          },
          "response": []
        },
